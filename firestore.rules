rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUserId() {
      return request.auth.uid;
    }

    function fallbackBusinessId() {
      return "business_" + currentUserId();
    }

    function businessUserDoc() {
      return get(/databases/$(database)/documents/business_users/$(currentUserId()));
    }

    function businessUserExists() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/business_users/$(currentUserId()));
    }

    function currentBusinessId() {
      return businessUserExists() ? businessUserDoc().data.business_id : null;
    }

    function belongsToCurrentBusiness(businessId) {
      return isAuthenticated() &&
        businessId != null &&
        (
          (businessUserExists() && currentBusinessId() == businessId) ||
          fallbackBusinessId() == businessId
        );
    }

    function sameBusinessResource() {
      return belongsToCurrentBusiness(resource.data.business_id) ||
        belongsToCurrentBusiness(resource.data.businessId);
    }

    function sameBusinessCreate() {
      return belongsToCurrentBusiness(request.resource.data.business_id) ||
        belongsToCurrentBusiness(request.resource.data.businessId);
    }

    function sameBusinessUpdate() {
      return sameBusinessResource() &&
        (
          request.resource.data.business_id == resource.data.business_id ||
          request.resource.data.businessId == resource.data.businessId ||
          request.resource.data.business_id == resource.data.businessId ||
          request.resource.data.businessId == resource.data.business_id
        );
    }

    function sameBusinessDelete() {
      return sameBusinessResource();
    }

    function isCurrentUserDocument(userId) {
      return isAuthenticated() && currentUserId() == userId;
    }

    match /business_users/{userId} {
      allow read: if isCurrentUserDocument(userId) || sameBusinessResource();
      allow create: if isCurrentUserDocument(userId) &&
        request.resource.data.business_id is string &&
        request.resource.data.display_name is string;
      allow update: if isCurrentUserDocument(userId) &&
        request.resource.data.business_id == resource.data.business_id ||
        sameBusinessUpdate();
    }

    match /businesses/{businessId} {
      allow read: if belongsToCurrentBusiness(businessId);
      allow create: if isAuthenticated() &&
        request.resource.data.owner_user_id == currentUserId();
      allow update: if belongsToCurrentBusiness(businessId) &&
        request.resource.data.owner_user_id == resource.data.owner_user_id;
    }

    match /products/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete();
    }

    match /tables/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete();
    }

    match /orders/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete();
    }

    match /tableSessions/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /orderItems/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /kitchenTickets/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /tableEvents/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if false;
      allow delete: if false;
    }

    match /sales_history/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
    }

    match /sales/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /saleItems/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /payments/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /cashMovements/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /paymentMethods/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /businessSettings/{businessId} {
      allow read: if belongsToCurrentBusiness(businessId);
      allow create: if sameBusinessCreate() || belongsToCurrentBusiness(businessId);
      allow update: if sameBusinessUpdate() || belongsToCurrentBusiness(businessId);
      allow delete: if false;
    }

    match /auditLogs/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if false;
      allow delete: if false;
    }

    match /accountsReceivable/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /receivablePayments/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /accountsPayable/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /payablePayments/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /customers/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete();
    }

    match /ticketPlans/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /mealTickets/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /ticketConsumptions/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /ticketAdjustments/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if false;
      allow delete: if false;
    }

    match /suppliers/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete();
    }

    match /ingredients/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete();
    }

    match /purchases/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete() &&
        resource.data.status == "borrador";
    }

    match /inventoryMovements/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if false;
      allow delete: if false;
    }

    match /preparations/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete();
    }

    match /recipeBooks/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete();
    }

    match /cash_closings/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
    }

    match /operating_expenses/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete();
    }

    match /resource_taxonomies/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete();
    }
  }
}
