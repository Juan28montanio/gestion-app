rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function currentUserId() {
      return request.auth.uid;
    }

    function fallbackBusinessId() {
      return "business_" + currentUserId();
    }

    function businessUserDoc() {
      return get(/databases/$(database)/documents/business_users/$(currentUserId()));
    }

    function businessUserExists() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/business_users/$(currentUserId()));
    }

    function currentBusinessId() {
      return businessUserExists() ? businessUserDoc().data.business_id : null;
    }

    function currentRole() {
      return businessUserExists() ? businessUserDoc().data.role : null;
    }

    function isOwnerOrAdmin() {
      return isAuthenticated() && (currentRole() == "owner" || currentRole() == "admin");
    }

    function belongsToCurrentBusiness(businessId) {
      return isAuthenticated() &&
        businessId != null &&
        (
          (businessUserExists() && currentBusinessId() == businessId) ||
          fallbackBusinessId() == businessId
        );
    }

    function sameBusinessResource() {
      return belongsToCurrentBusiness(resource.data.business_id) ||
        belongsToCurrentBusiness(resource.data.businessId);
    }

    function sameBusinessCreate() {
      return belongsToCurrentBusiness(request.resource.data.business_id) ||
        belongsToCurrentBusiness(request.resource.data.businessId);
    }

    function sameBusinessUpdate() {
      return sameBusinessResource() &&
        (
          request.resource.data.business_id == resource.data.business_id ||
          request.resource.data.businessId == resource.data.businessId ||
          request.resource.data.business_id == resource.data.businessId ||
          request.resource.data.businessId == resource.data.business_id
        );
    }

    function sameBusinessDelete() {
      return sameBusinessResource();
    }

    function validBusinessCreate() {
      return request.resource.data.business_id is string ||
        request.resource.data.businessId is string;
    }

    function immutableBusinessId() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(["business_id", "businessId"]);
    }

    function hasOnlyChanged(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    function validSaleStatus(status) {
      return status in ["pending", "partial", "paid", "canceled", "refunded"];
    }

    function validPaymentStatus(status) {
      return status in ["pending", "completed", "partial", "canceled", "refunded"];
    }

    function validInventoryImpactStatus(status) {
      return status in ["pending", "applied", "not_applicable", "failed", "reversed"];
    }

    function validCashMovementStatus(status) {
      return status in ["valid", "reversed", "canceled"];
    }

    function isCurrentUserDocument(userId) {
      return isAuthenticated() && currentUserId() == userId;
    }

    match /business_users/{userId} {
      allow read: if isCurrentUserDocument(userId) || sameBusinessResource();
      allow create: if isCurrentUserDocument(userId) &&
        request.resource.data.business_id is string &&
        request.resource.data.display_name is string;
      allow update: if isCurrentUserDocument(userId) &&
        request.resource.data.business_id == resource.data.business_id ||
        sameBusinessUpdate();
    }

    match /businesses/{businessId} {
      allow read: if belongsToCurrentBusiness(businessId);
      allow create: if isAuthenticated() &&
        request.resource.data.owner_user_id == currentUserId();
      allow update: if belongsToCurrentBusiness(businessId) &&
        request.resource.data.owner_user_id == resource.data.owner_user_id;
    }

    match /products/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate() && validBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete() && isOwnerOrAdmin();
    }

    match /tables/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate() && validBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete() && isOwnerOrAdmin();
    }

    match /orders/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /tableSessions/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /orderItems/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /kitchenTickets/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /tableEvents/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if false;
      allow delete: if false;
    }

    match /sales_history/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate() && validBusinessCreate() &&
        request.resource.data.total is number;
      allow update: if sameBusinessUpdate() &&
        immutableBusinessId() &&
        hasOnlyChanged([
          "concept",
          "closing_id",
          "closed_at",
          "pending_debt_remaining",
          "settled_amount",
          "payment_status",
          "updatedAt"
        ]);
      allow delete: if false;
    }

    match /sales/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate() && validBusinessCreate() &&
        request.resource.data.total is number &&
        request.resource.data.total >= 0 &&
        validSaleStatus(request.resource.data.status) &&
        validInventoryImpactStatus(request.resource.data.inventoryImpactStatus);
      allow update: if sameBusinessUpdate() &&
        immutableBusinessId() &&
        hasOnlyChanged([
          "status",
          "cancelReason",
          "cancel_reason",
          "canceledBy",
          "canceled_by",
          "canceledAt",
          "canceled_at",
          "inventoryImpactStatus",
          "inventory_impact_status",
          "inventoryAppliedAt",
          "inventory_applied_at",
          "inventoryReversedAt",
          "inventory_reversed_at",
          "inventoryReverseReason",
          "inventory_reverse_reason",
          "inventoryImpactError",
          "inventory_impact_error",
          "cashSessionId",
          "cash_session_id",
          "updatedAt",
          "updatedBy",
          "updated_by"
        ]) &&
        (!request.resource.data.keys().hasAny(["status"]) || validSaleStatus(request.resource.data.status)) &&
        (!request.resource.data.keys().hasAny(["inventoryImpactStatus"]) || validInventoryImpactStatus(request.resource.data.inventoryImpactStatus));
      allow delete: if false;
    }

    match /saleItems/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate() && validBusinessCreate() &&
        request.resource.data.sale_id is string &&
        request.resource.data.quantity is number &&
        request.resource.data.quantity > 0;
      allow update: if false;
      allow delete: if false;
    }

    match /payments/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate() && validBusinessCreate() &&
        request.resource.data.sale_id is string &&
        request.resource.data.amount is number &&
        request.resource.data.amount >= 0 &&
        validPaymentStatus(request.resource.data.status);
      allow update: if sameBusinessUpdate() &&
        immutableBusinessId() &&
        hasOnlyChanged([
          "status",
          "cancelReason",
          "cancel_reason",
          "canceledBy",
          "canceled_by",
          "canceledAt",
          "canceled_at",
          "updatedAt"
        ]) &&
        validPaymentStatus(request.resource.data.status);
      allow delete: if false;
    }

    match /cashMovements/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate() && validBusinessCreate() &&
        request.resource.data.amount is number &&
        request.resource.data.amount >= 0;
      allow update: if sameBusinessUpdate() &&
        immutableBusinessId() &&
        hasOnlyChanged([
          "status",
          "reverseReason",
          "reverse_reason",
          "reversedAt",
          "reversed_at",
          "reversedBy",
          "reversed_by",
          "updatedAt"
        ]) &&
        (!request.resource.data.keys().hasAny(["status"]) || validCashMovementStatus(request.resource.data.status));
      allow delete: if false;
    }

    match /paymentMethods/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete() && isOwnerOrAdmin();
    }

    match /businessSettings/{businessId} {
      allow read: if belongsToCurrentBusiness(businessId);
      allow create: if sameBusinessCreate() || belongsToCurrentBusiness(businessId);
      allow update: if sameBusinessUpdate() || belongsToCurrentBusiness(businessId);
      allow delete: if false;
    }

    match /onboardingProgress/{businessId} {
      allow read: if belongsToCurrentBusiness(businessId);
      allow create: if belongsToCurrentBusiness(businessId) &&
        request.resource.data.business_id == businessId;
      allow update: if belongsToCurrentBusiness(businessId) &&
        request.resource.data.business_id == resource.data.business_id;
      allow delete: if belongsToCurrentBusiness(businessId) && isOwnerOrAdmin();
    }

    match /auditLogs/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if false;
      allow delete: if false;
    }

    match /accountsReceivable/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate() && validBusinessCreate() &&
        request.resource.data.originalAmount is number &&
        request.resource.data.pendingAmount is number;
      allow update: if sameBusinessUpdate() &&
        immutableBusinessId() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(["originalAmount", "original_amount", "saleId", "sale_id"]);
      allow delete: if false;
    }

    match /receivablePayments/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /accountsPayable/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate() && validBusinessCreate() &&
        request.resource.data.originalAmount is number &&
        request.resource.data.pendingAmount is number;
      allow update: if sameBusinessUpdate() &&
        immutableBusinessId() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(["originalAmount", "original_amount", "purchaseId", "purchase_id"]);
      allow delete: if false;
    }

    match /payablePayments/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /customers/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete() && isOwnerOrAdmin();
    }

    match /ticketPlans/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /mealTickets/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /ticketConsumptions/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if false;
    }

    match /ticketAdjustments/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if false;
      allow delete: if false;
    }

    match /suppliers/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete() && isOwnerOrAdmin();
    }

    match /ingredients/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete() && isOwnerOrAdmin();
    }

    match /purchases/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete() && isOwnerOrAdmin() &&
        resource.data.status == "borrador";
    }

    match /inventoryMovements/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate() && validBusinessCreate() &&
        request.resource.data.inventory_item_id is string &&
        request.resource.data.quantity is number &&
        request.resource.data.quantity > 0;
      allow update: if sameBusinessUpdate() &&
        immutableBusinessId() &&
        hasOnlyChanged([
          "status",
          "reversedAt",
          "reversed_at",
          "reverseReason",
          "reverse_reason"
        ]) &&
        request.resource.data.status in ["reversed"];
      allow delete: if false;
    }

    match /preparations/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete() && isOwnerOrAdmin();
    }

    match /recipeBooks/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete() && isOwnerOrAdmin();
    }

    match /cash_closings/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate() && validBusinessCreate();
      allow update: if sameBusinessUpdate() &&
        immutableBusinessId() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(["sales_total", "expected_cash", "opening_amount"]);
      allow delete: if false;
    }

    match /operating_expenses/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete() && isOwnerOrAdmin();
    }

    match /resource_taxonomies/{documentId} {
      allow read: if sameBusinessResource();
      allow create: if sameBusinessCreate();
      allow update: if sameBusinessUpdate();
      allow delete: if sameBusinessDelete() && isOwnerOrAdmin();
    }
  }
}
